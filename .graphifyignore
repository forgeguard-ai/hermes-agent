__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- JS / packaging noise ---
node_modules/
package-lock.json
uv.lock
flake.lock

# --- Graphify's own output ---
graphify-out/

